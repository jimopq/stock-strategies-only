# FinMind API (免費註冊: https://finmindtrade.com/)
FINMIND_TOKEN=your_finmind_token_here

# Telegram Bot (找 @BotFather 建立)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 你自己的 chat id (找 @userinfobot 取得)。聊天機器人只回應這個 id
TELEGRAM_CHAT_ID=your_chat_id_here

# Gemini API — AI 聊天腦 + 每日 AI 短評
# 免費申請: https://aistudio.google.com/apikey
# 不設也能跑，但機器人只剩斜線指令、每日推播沒有 AI 短評
GEMINI_API_KEY=your_gemini_api_key_here
# 可選，預設 gemini-3.6-flash
# 注意 gemini-2.5-flash 對新申請的 key 已停止提供（呼叫會 404）
# GEMINI_MODEL=gemini-3.6-flash

# Google Sheet
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Service Account JSON (整串壓成一行)
GOOGLE_CREDS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
